"use client"

import type React from "react"
import { useEffect, useRef, useState, useCallback } from "react"
import * as turf from "@turf/turf"
import { Button } from "@/components/ui/button"
import { Download, Upload, Info, MapPin, Trash2, Eye, EyeOff, Edit2, Plus, Copy, Target, Scissors, Split } from "lucide-react"
import { Slider } from "@/components/ui/slider"
import { Label } from "@/components/ui/label"
import { Switch } from "@/components/ui/switch"
import { Card } from "@/components/ui/card"
import { Input } from "@/components/ui/input"

interface MapStats {
  area: number
  perimeter: number
  count: number
}

interface PolygonMetadata {
  id: string
  name: string
  color: string
  visible: boolean
  layer: any
}

// Define DeliveryZone interface
interface DeliveryZone {
  locationId: string
  location: { lat: number; lng: number }
  territory: any // The main delivery boundary
  subZones: Array<{ time: number; polygon: any }> // Nested drive-time zones
  color: string
  name: string
  visible: boolean
  territoryLayer?: any
}

const loadLeaflet = () => {
  return new Promise<void>((resolve, reject) => {
    if (typeof window !== "undefined" && (window as any).L) {
      resolve()
      return
    }

    const cssLink = document.createElement("link")
    cssLink.rel = "stylesheet"
    cssLink.href = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    document.head.appendChild(cssLink)

    const drawCssLink = document.createElement("link")
    drawCssLink.rel = "stylesheet"
    drawCssLink.href = "https://unpkg.com/leaflet-draw@1.0.4/dist/leaflet.draw.css"
    document.head.appendChild(drawCssLink)

    const leafletScript = document.createElement("script")
    leafletScript.src = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    leafletScript.onload = () => {
      const drawScript = document.createElement("script")
      drawScript.src = "https://unpkg.com/leaflet-draw@1.0.4/dist/leaflet.draw.js"
      drawScript.onload = () => resolve()
      drawScript.onerror = () => reject(new Error("Failed to load Leaflet Draw"))
      document.head.appendChild(drawScript)
    }
    leafletScript.onerror = () => reject(new Error("Failed to load Leaflet"))
    document.head.appendChild(leafletScript)
  })
}

export default function MapEditor() {
  const mapRef = useRef<HTMLDivElement>(null)
  const mapInstanceRef = useRef<any>(null)
  const featureGroupRef = useRef<any>(null)
  const fileInputRef = useRef<HTMLInputElement>(null)
  const contextMenuRef = useRef<HTMLDivElement>(null)
  const [isMapReady, setIsMapReady] = useState(false)

  const [tolerance, setTolerance] = useState(0.001)
  const [showSimplified, setShowSimplified] = useState(false)
  const [stats, setStats] = useState<MapStats | null>(null)
  const [originalGeoJSON, setOriginalGeoJSON] = useState<any>(null)
  const [simplifiedGeoJSON, setSimplifiedGeoJSON] = useState<any>(null)

  const [latitude, setLatitude] = useState("33.4484")
  const [longitude, setLongitude] = useState("-112.074")
  const [driveTime, setDriveTime] = useState("15")
  const [isGenerating, setIsGenerating] = useState(false)
  const [apiKey, setApiKey] = useState("eyJvcmciOiI1YjNjZTM1OTc4NTExMTAwMDFjZjYyNDgiLCJpZCI6ImY3YTc0MThiMGI1NjRhMmI4YTk3MDU0YjE5ZWQ5ZDcxIiwiaCI6Im11cm11cjY0In0=")
  const [useCircularFallback, setUseCircularFallback] = useState(false)

  const [multiSelectMode, setMultiSelectMode] = useState(false)
  const [selectedVertices, setSelectedVertices] = useState<Set<string>>(new Set())
  const selectedMarkersRef = useRef<Map<string, any>>(new Map())

  const [isDragging, setIsDragging] = useState(false)
  const [dragStart, setDragStart] = useState<{ x: number; y: number } | null>(null)
  const [dragEnd, setDragEnd] = useState<{ x: number; y: number } | null>(null)
  const selectionBoxRef = useRef<HTMLDivElement | null>(null)

  const [polygons, setPolygons] = useState<PolygonMetadata[]>([])
  const [contextMenu, setContextMenu] = useState<{ x: number; y: number; lat: number; lng: number } | null>(null)
  const [selectedPolygonId, setSelectedPolygonId] = useState<string | null>(null)
  const [editingPolygonId, setEditingPolygonId] = useState<string | null>(null)
  const [editingName, setEditingName] = useState("")

  // Use deliveryZones state and related logic
  const [deliveryZones, setDeliveryZones] = useState<DeliveryZone[]>([])
  const [editingZoneId, setEditingZoneId] = useState<string | null>(null)
  const [editingZoneName, setEditingZoneName] = useState("")
  const [selectedZonesForMerge, setSelectedZonesForMerge] = useState<Set<string>>(new Set())
  
  // Multi-location zone generation
  const [multiLocations, setMultiLocations] = useState("")
  const [multiDriveTimes, setMultiDriveTimes] = useState("5,10,15")
  const [locationCenters, setLocationCenters] = useState<Array<{ lat: number; lng: number; id: string }>>([])
  
  // Zone checking mode
  const [checkPointMode, setCheckPointMode] = useState(false)
  const [lastCheckedPoint, setLastCheckedPoint] = useState<{ lat: number; lng: number; zone: string } | null>(null)
  
  // Zone generation mode (single vs multi)
  const [zoneMode, setZoneMode] = useState<"single" | "multi">("multi")
  
  // Region split mode
  const [splitMode, setSplitMode] = useState(false)
  const [splitLines, setSplitLines] = useState<Array<[[number, number], [number, number]]>>([])
  const [currentSplitLine, setCurrentSplitLine] = useState<[number, number] | null>(null)
  const [polygonToSplit, setPolygonToSplit] = useState<string | null>(null)
  const splitLinesLayerRef = useRef<any>(null)

  const updateDeliveryZoneTerritory = useCallback((zoneId: string, editedLayer: any) => {
    console.log("[v0] Updating delivery zone territory for", zoneId)

    try {
      const L = (window as any).L

      // Get the new coordinates from the edited layer using proper Leaflet API
      const latlngs = editedLayer.getLatLngs()[0]

      // Convert to GeoJSON coordinates [lng, lat]
      const coords = latlngs.map((ll: any) => [ll.lng, ll.lat])
      coords.push(coords[0]) // Close the polygon

      const newTerritory = turf.polygon([coords])

      // Update the delivery zone state
      setDeliveryZones((prev) =>
        prev.map((zone) => {
          if (zone.locationId === zoneId) {
            console.log("[v0] Found zone to update:", zone.name)

            // Update territory
            const updatedZone = { ...zone, territory: newTerritory }

            // Clip sub-zones to new territory
            const updatedSubZones = zone.subZones.map((subZone) => {
              try {
                const clipped = turf.intersect(turf.featureCollection([newTerritory, subZone.polygon]))
                return {
                  time: subZone.time,
                  polygon: clipped || subZone.polygon,
                }
              } catch (error) {
                console.log("[v0] Error clipping sub-zone, keeping original")
                return subZone
              }
            })

            updatedZone.subZones = updatedSubZones

            // Remove old sub-zone layers from map
            if (mapInstanceRef.current) {
              mapInstanceRef.current.eachLayer((layer: any) => {
                if (
                  layer.options &&
                  layer.options.zoneId === zoneId &&
                  layer.options.isDeliveryZone &&
                  !layer.options.isTerritoryBoundary
                ) {
                  mapInstanceRef.current.removeLayer(layer)
                }
              })

              // Redraw sub-zones with new clipped polygons
              updatedSubZones.forEach((subZone, idx) => {
                const opacity = 0.15 + idx * 0.2
                L.geoJSON(subZone.polygon, {
                  style: {
                    color: zone.color,
                    weight: 1,
                    fillColor: zone.color,
                    fillOpacity: opacity,
                  },
                  zoneId: zone.locationId,
                  isDeliveryZone: true,
                })
                  .bindTooltip(`${zone.name} - ${subZone.time} min`, { sticky: true })
                  .addTo(mapInstanceRef.current)
              })
            }

            console.log("[v0] Successfully updated zone with", updatedSubZones.length, "sub-zones")
            return updatedZone
          }
          return zone
        }),
      )
    } catch (error) {
      console.error("[v0] Error updating delivery zone territory:", error)
    }
  }, [])

  useEffect(() => {
    const handleError = (event: ErrorEvent) => {
      // Suppress generic "Script error" from cross-origin scripts (Leaflet CDN)
      if (event.message === "Script error.") {
        console.log("[v0] Suppressed cross-origin script error (likely from Leaflet CDN)")
        event.preventDefault()
        return true
      }
    }

    window.addEventListener("error", handleError)
    return () => window.removeEventListener("error", handleError)
  }, [])

  useEffect(() => {
    if (typeof window === "undefined" || !mapRef.current || isMapReady) return

    const initMap = async () => {
      try {
        await loadLeaflet()
        const L = (window as any).L

        const map = L.map(mapRef.current, {
          zoomControl: false,
        }).setView([33.4484, -112.074], 10)

        L.control
          .zoom({
            position: "topright",
          })
          .addTo(map)

        const streetLayer = L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
        })

        const satelliteLayer = L.tileLayer(
          "https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}",
          {
            attribution: "&copy; Esri",
          },
        )

        streetLayer.addTo(map)

        L.control
          .layers(
            {
              Street: streetLayer,
              Satellite: satelliteLayer,
            },
            {},
            { position: "topright" },
          )
          .addTo(map)

        const featureGroup = L.featureGroup().addTo(map)
        featureGroupRef.current = featureGroup

        const drawControl = new L.Control.Draw({
          position: "topright",
          edit: {
            featureGroup: featureGroup,
            edit: true,
            remove: true,
          },
          draw: {
            polygon: {
              allowIntersection: false,
              showArea: true,
              shapeOptions: {
                color: "#3b82f6",
                weight: 2,
                fillOpacity: 0.2,
              },
            },
            polyline: false,
            rectangle: false,
            circle: false,
            circlemarker: false,
            marker: false,
          },
        })
        map.addControl(drawControl)

        map.on(L.Draw.Event.CREATED, (e: any) => {
          const layer = e.layer
          featureGroup.addLayer(layer)

          const newPolygon: PolygonMetadata = {
            id: L.stamp(layer).toString(),
            name: `Zone ${polygons.length + 1}`,
            color: "#3b82f6",
            visible: true,
            layer: layer,
          }

          setPolygons((prev) => [...prev, newPolygon])
          updateGeoJSON()
        })

        map.on(L.Draw.Event.EDITED, (e: any) => {
          const layers = e.layers
          let hasDeliveryZone = false

          layers.eachLayer((layer: any) => {
            if (layer.options && layer.options.isDeliveryZone && layer.options.zoneId) {
              hasDeliveryZone = true
              // Update the delivery zone with new territory
              updateDeliveryZoneTerritory(layer.options.zoneId, layer)
            }
          })

          // Only update regular GeoJSON if no delivery zones were edited
          if (!hasDeliveryZone) {
            updateGeoJSON()
          }
        })

        map.on(L.Draw.Event.DELETED, (e: any) => {
          const deletedLayers = e.layers
          deletedLayers.eachLayer((layer: any) => {
            const layerId = L.stamp(layer).toString()
            setPolygons((prev) => prev.filter((p) => p.id !== layerId))

            // If a delivery zone territory was deleted, remove it from state
            if (layer.options && layer.options.isDeliveryZone && layer.options.zoneId) {
              setDeliveryZones((prev) => prev.filter((zone) => zone.locationId !== layer.options.zoneId))
              // Also remove associated sub-zone layers
              if (mapInstanceRef.current) {
                mapInstanceRef.current.eachLayer((l: any) => {
                  if (l.options && l.options.zoneId === layer.options.zoneId && l.options.isDeliveryZone) {
                    mapInstanceRef.current.removeLayer(l)
                  }
                })
              }
            }
          })
          updateGeoJSON()
        })

        map.on("contextmenu", (e: any) => {
          e.originalEvent.preventDefault()
          const containerPoint = map.latLngToContainerPoint(e.latlng)
          const mapContainer = mapRef.current?.getBoundingClientRect()

          if (mapContainer) {
            setContextMenu({
              x: mapContainer.left + containerPoint.x,
              y: mapContainer.top + containerPoint.y,
              lat: e.latlng.lat,
              lng: e.latlng.lng,
            })
          }
        })

        mapInstanceRef.current = map
        setIsMapReady(true)
      } catch (error) {
        console.error("Error initializing map:", error)
      }
    }

    initMap()

    return () => {
      if (mapInstanceRef.current) {
        mapInstanceRef.current.remove()
        mapInstanceRef.current = null
      }
    }
  }, [])

  useEffect(() => {
    const handleClickOutside = (e: MouseEvent) => {
      if (contextMenuRef.current && !contextMenuRef.current.contains(e.target as Node)) {
        setContextMenu(null)
      }
    }

    if (contextMenu) {
      document.addEventListener("mousedown", handleClickOutside)
      return () => document.removeEventListener("mousedown", handleClickOutside)
    }
  }, [contextMenu])

  const addLocationCenter = useCallback((lat: number, lng: number) => {
    const newLocation = {
      lat,
      lng,
      id: `loc-${Date.now()}`,
    }

    setLocationCenters((prev) => [...prev, newLocation])

    setMultiLocations((prev) => {
      const newLine = `${lat.toFixed(4)},${lng.toFixed(4)}`
      return prev ? `${prev}\n${newLine}` : newLine
    })

    if (mapInstanceRef.current) {
      const L = (window as any).L
      L.marker([lat, lng], {
        icon: L.divIcon({
          className: "bg-red-500 rounded-full w-4 h-4 border-2 border-white shadow-lg",
          iconSize: [16, 16],
        }),
      }).addTo(mapInstanceRef.current)
    }

    setContextMenu(null)
  }, [])

  const copyCoordinates = useCallback((lat: number, lng: number) => {
    const coordText = `${lat.toFixed(6)}, ${lng.toFixed(6)}`
    navigator.clipboard
      .writeText(coordText)
      .then(() => {
        alert("Coordinates copied to clipboard!")
      })
      .catch(() => {
        alert("Failed to copy coordinates")
      })
    setContextMenu(null)
  }, [])

  useEffect(() => {
    if (!mapRef.current || !multiSelectMode || !isMapReady) return

    const mapContainer = mapRef.current
    const L = (window as any).L
    const map = mapInstanceRef.current

    const handleMouseDown = (e: MouseEvent) => {
      if ((e.target as HTMLElement).closest(".leaflet-control-container")) return

      if (map && map.dragging) {
        map.dragging.disable()
      }

      setIsDragging(true)
      setDragStart({ x: e.clientX, y: e.clientY })
      setDragEnd({ x: e.clientX, y: e.clientY })
      e.preventDefault()
      e.stopPropagation()
    }

    const handleMouseMove = (e: MouseEvent) => {
      if (!isDragging) return
      setDragEnd({ x: e.clientX, y: e.clientY })
      e.preventDefault()
    }

    const handleMouseUp = (e: MouseEvent) => {
      if (!isDragging || !dragStart || !dragEnd) {
        if (map && map.dragging) {
          map.dragging.enable()
        }
        return
      }

      const minX = Math.min(dragStart.x, dragEnd.x)
      const maxX = Math.max(dragStart.x, dragEnd.x)
      const minY = Math.min(dragStart.y, dragEnd.y)
      const maxY = Math.max(dragStart.y, dragEnd.y)

      const newSelected = new Set(selectedVertices)

      featureGroupRef.current?.eachLayer((layer: any) => {
        if (layer.getLatLngs) {
          const latlngs = layer.getLatLngs()[0]
          latlngs.forEach((latlng: any, index: number) => {
            const vertexPoint = mapInstanceRef.current.latLngToContainerPoint(latlng)
            const vertexScreenX = vertexPoint.x + mapContainer.getBoundingClientRect().left
            const vertexScreenY = vertexPoint.y + mapContainer.getBoundingClientRect().top

            if (vertexScreenX >= minX && vertexScreenX <= maxX && vertexScreenY >= minY && vertexScreenY <= maxY) {
              const vertexId = `${L.stamp(layer)}-${index}`
              newSelected.add(vertexId)

              if (!selectedMarkersRef.current.has(vertexId)) {
                const marker = L.circleMarker(latlng, {
                  radius: 6,
                  fillColor: "#ef4444",
                  color: "#fff",
                  weight: 2,
                  fillOpacity: 1,
                }).addTo(mapInstanceRef.current)
                selectedMarkersRef.current.set(vertexId, marker)
              }
            }
          })
        }
      })

      setSelectedVertices(newSelected)
      setIsDragging(false)
      setDragStart(null)
      setDragEnd(null)

      if (map && map.dragging) {
        map.dragging.enable()
      }
    }

    mapContainer.addEventListener("mousedown", handleMouseDown)
    window.addEventListener("mousemove", handleMouseMove)
    window.addEventListener("mouseup", handleMouseUp)

    return () => {
      mapContainer.removeEventListener("mousedown", handleMouseDown)
      window.removeEventListener("mousemove", handleMouseMove)
      window.removeEventListener("mouseup", handleMouseUp)
      if (map && map.dragging) {
        map.dragging.enable()
      }
    }
  }, [multiSelectMode, isMapReady, isDragging, dragStart, dragEnd, selectedVertices])

  const calculateStats = useCallback((geojson: any) => {
    if (!geojson || !geojson.features) return null

    let totalArea = 0
    let totalPerimeter = 0
    let count = 0

    geojson.features.forEach((feature: any) => {
      if (feature.geometry.type === "Polygon" || feature.geometry.type === "MultiPolygon") {
        try {
          const area = turf.area(feature)
          const perimeter = turf.length(turf.polygonToLine(feature as any), { units: "meters" })
          totalArea += area
          totalPerimeter += perimeter
          count++
        } catch (error) {
          console.error("Error calculating stats:", error)
        }
      }
    })

    return { area: totalArea, perimeter: totalPerimeter, count }
  }, [])

  const updateGeoJSON = useCallback(async () => {
    if (!featureGroupRef.current) return

    const L = (window as any).L
    const layers = featureGroupRef.current.toGeoJSON()
    setOriginalGeoJSON(layers)

    if (layers.features && layers.features.length > 0) {
      try {
        const simplified = {
          ...layers,
          features: layers.features.map((feature: any) => {
            try {
              return turf.simplify(feature, { tolerance, highQuality: true })
            } catch (error) {
              console.error("Error simplifying feature:", error)
              return feature
            }
          }),
        }
        setSimplifiedGeoJSON(simplified)
      } catch (error) {
        console.error("Error creating simplified GeoJSON:", error)
        setSimplifiedGeoJSON(layers)
      }
    } else {
      setSimplifiedGeoJSON(null)
    }

    const currentStats = calculateStats(layers)
    setStats(currentStats)
  }, [tolerance, calculateStats])

  const generateDeliveryZones = async () => {
    if (!isMapReady || !mapInstanceRef.current) return

    const locations = multiLocations.split("\n").filter((l) => l.trim())
    const times = multiDriveTimes
      .split(",")
      .map((t) => Number.parseInt(t.trim()))
      .filter((t) => !isNaN(t))
      .sort((a, b) => a - b) // Sort ascending for proper API call

    if (locations.length === 0 || times.length === 0) {
      alert("Please enter at least one location and drive time")
      return
    }

    if (!apiKey && !useCircularFallback) {
      alert("Please enter an OpenRouteService API key or enable circular approximation mode")
      return
    }

    setIsGenerating(true)
    console.log("[v0] Starting delivery zone generation for", locations.length, "locations")

    try {
      const L = (window as any).L
      const colors = ["#3b82f6", "#10b981", "#f59e0b", "#ef4444", "#8b5cf6", "#ec4899", "#06b6d4"]
      const newZones: DeliveryZone[] = []

      // Clear existing delivery zone layers
      mapInstanceRef.current.eachLayer((layer: any) => {
        if (layer.options && layer.options.isDeliveryZone) {
          mapInstanceRef.current.removeLayer(layer)
        }
      })

      const locationIsochrones: Array<{
        location: { lat: number; lng: number }
        locationId: string
        isochrones: Array<{ time: number; polygon: any }>
        color: string
      }> = []

      // Step 1: Generate isochrones for all locations
      for (let i = 0; i < locations.length; i++) {
        const [latStr, lngStr] = locations[i].split(",").map((s) => s.trim())
        const lat = Number.parseFloat(latStr)
        const lng = Number.parseFloat(lngStr)

        if (isNaN(lat) || isNaN(lng)) {
          console.log("[v0] Skipping invalid location:", locations[i])
          continue
        }

        const locationId = `loc-${i}`
        const color = colors[i % colors.length]
        console.log("[v0] Generating isochrones for location", i, "at", lat, lng, "for times", times)

        try {
          const isochrones: Array<{ time: number; polygon: any }> = []
          
          if (useCircularFallback || !apiKey) {
            // Use circular approximation (1 km per minute of drive time)
            console.log("[v0] Using circular approximation for location", i)
            for (const time of times) {
              const radiusKm = time * 1.0 // 1 km per minute approximation
              const circle = turf.circle([lng, lat], radiusKm, { steps: 64, units: "kilometers" })
              isochrones.push({ time, polygon: circle })
            }
          } else {
            // Use OpenRouteService API
            const response = await fetch("/api/isochrone", {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
              },
              body: JSON.stringify({
                apiKey,
                locations: [[lng, lat]],
                range: times.map((t) => t * 60), // Convert minutes to seconds
                range_type: "time",
              }),
            })

            if (!response.ok) {
              const errorData = await response.json().catch(() => ({}))
              console.error("[v0] API error:", response.status, errorData)
              throw new Error(errorData.error || `API returned ${response.status}`)
            }

            const data = await response.json()
            console.log("[v0] Received", data.features.length, "isochrones for location", i)

            data.features.forEach((feature: any, idx: number) => {
              const time = times[idx]
              const simplified = turf.simplify(feature, { tolerance: 0.0005, highQuality: true })
              isochrones.push({ time, polygon: simplified })
            })
          }

          locationIsochrones.push({
            location: { lat, lng },
            locationId,
            isochrones,
            color,
          })

          // Add location marker
          L.marker([lat, lng], {
            icon: L.divIcon({
              className:
                "bg-white rounded-full w-6 h-6 border-3 border-current shadow-lg flex items-center justify-center text-xs font-bold",
              html: `<div style="color: ${color}">${i + 1}</div>`,
              iconSize: [24, 24],
            }),
          })
            .addTo(mapInstanceRef.current)
            .bindTooltip(`Location ${i + 1}`, { permanent: false })
        } catch (error) {
          console.error("[v0] Failed to generate isochrones for location", i, error)
          alert(`Failed to generate zones for location ${i + 1}. ${apiKey ? 'Check API key and try again, or enable circular approximation mode.' : 'Enable circular approximation mode or add an API key.'}`)
          setIsGenerating(false)
          return
        }
      }

      if (locationIsochrones.length === 0) {
        alert("No valid locations to process")
        setIsGenerating(false)
        return
      }

      console.log("[v0] Successfully generated isochrones for", locationIsochrones.length, "locations")

      const locationPoints = turf.featureCollection(
        locationIsochrones.map((loc) =>
          turf.point([loc.location.lng, loc.location.lat], { locationId: loc.locationId }),
        ),
      )

      // Create a bounding box that encompasses all isochrones
      const allIsochrones = locationIsochrones.flatMap((loc) => loc.isochrones.map((iso) => iso.polygon))
      const combinedIsochrones = turf.featureCollection(allIsochrones)
      const bbox = turf.bbox(combinedIsochrones)

      // Expand bbox slightly to ensure Voronoi covers everything
      const bboxPadding = 0.1 // degrees
      const expandedBbox: [number, number, number, number] = [
        bbox[0] - bboxPadding,
        bbox[1] - bboxPadding,
        bbox[2] + bboxPadding,
        bbox[3] + bboxPadding,
      ]

      // Generate Voronoi diagram
      const voronoiPolygons = turf.voronoi(locationPoints, { bbox: expandedBbox })
      console.log("[v0] Created Voronoi diagram with", voronoiPolygons.features.length, "cells")

      // Step 3: For each location, create territory by clipping isochrones to Voronoi cell
      for (let i = 0; i < locationIsochrones.length; i++) {
        const currentLoc = locationIsochrones[i]

        // Find the Voronoi cell for this location
        const voronoiCell = voronoiPolygons.features.find(
          (feature: any) => feature.properties.locationId === currentLoc.locationId,
        )

        if (!voronoiCell) {
          console.error("[v0] No Voronoi cell found for location", i)
          continue
        }

        // Use the largest isochrone as the base, clipped to the Voronoi cell
        const maxIsochrone = currentLoc.isochrones[currentLoc.isochrones.length - 1].polygon

        let territory
        try {
          // Clip the max isochrone to the Voronoi cell
          const clipped = turf.intersect(turf.featureCollection([maxIsochrone, voronoiCell]))
          territory = clipped || maxIsochrone // Fallback to max isochrone if clipping fails
        } catch (error) {
          console.log("[v0] Error clipping territory for location", i, "using max isochrone")
          territory = maxIsochrone
        }

        // Create sub-zones by clipping each isochrone to the territory
        const subZones: Array<{ time: number; polygon: any }> = []
        for (const iso of currentLoc.isochrones) {
          try {
            const clipped = turf.intersect(turf.featureCollection([territory, iso.polygon]))
            if (clipped) {
              subZones.push({
                time: iso.time,
                polygon: clipped,
              })
            } else {
              // If no intersection, the isochrone might be fully within territory
              subZones.push({
                time: iso.time,
                polygon: iso.polygon,
              })
            }
          } catch (error) {
            // If clipping fails, use original
            subZones.push({
              time: iso.time,
              polygon: iso.polygon,
            })
          }
        }

        const zoneName = `Location ${i + 1}`
        const zone: DeliveryZone = {
          locationId: currentLoc.locationId,
          location: currentLoc.location,
          territory,
          subZones,
          color: currentLoc.color,
          name: zoneName,
          visible: true,
        }

        try {
          // Extract coordinates from the territory GeoJSON
          const coords = territory.geometry.coordinates[0].map((coord: number[]) => [coord[1], coord[0]])

          // Create a simple Leaflet polygon
          const territoryPolygon = L.polygon(coords, {
            color: currentLoc.color,
            weight: 3,
            fillOpacity: 0,
            dashArray: "8, 4",
            zoneId: currentLoc.locationId,
            isDeliveryZone: true,
            isTerritoryBoundary: true, // Mark as territory boundary to distinguish from sub-zones
          })

          // Add to feature group so it's editable
          featureGroupRef.current?.addLayer(territoryPolygon)

          // Store reference to the layer
          zone.territoryLayer = territoryPolygon

          territoryPolygon.bindTooltip(`${zoneName} Territory`, { sticky: true })

          console.log("[v0] Created editable territory boundary for location", i)
        } catch (territoryError) {
          console.log("[v0] Territory layer creation error:", territoryError.message)
        }

        // Display sub-zones with increasing opacity (visual only, not editable)
        try {
          subZones.forEach((subZone, idx) => {
            const opacity = 0.15 + idx * 0.2
            L.geoJSON(subZone.polygon, {
              style: {
                color: currentLoc.color,
                weight: 1,
                fillColor: currentLoc.color,
                fillOpacity: opacity,
              },
              zoneId: currentLoc.locationId,
              isDeliveryZone: true,
            })
              .bindTooltip(`${zoneName} - ${subZone.time} min`, { sticky: true })
              .addTo(mapInstanceRef.current)
          })
        } catch (subZoneError) {
          console.log("[v0] Sub-zone layer creation error:", subZoneError.message)
        }

        newZones.push(zone)

        console.log(
          "[v0] Created zone for location",
          i,
          "with",
          subZones.length,
          "sub-zones at times:",
          subZones.map((s) => s.time),
        )
      }

      setDeliveryZones(newZones)
      console.log("[v0] Successfully created", newZones.length, "delivery zones with Voronoi territories")

      // Fit map to show all zones
      if (newZones.length > 0) {
        const allPolygons = newZones.flatMap((z) => z.subZones.map((s) => s.polygon))
        const combined = turf.featureCollection(allPolygons)
        const bbox = turf.bbox(combined)
        mapInstanceRef.current.fitBounds(
          [
            [bbox[1], bbox[0]],
            [bbox[3], bbox[2]],
          ],
          { padding: [50, 50] },
        )
      }
    } catch (error) {
      console.error("[v0] Error generating delivery zones:", error)
      alert("Failed to generate delivery zones. Check console for details.")
    } finally {
      setIsGenerating(false)
    }
  }

  const renameDeliveryZone = useCallback((locationId: string, name: string) => {
    setDeliveryZones((prev) =>
      prev.map((z) => {
        if (z.locationId === locationId) {
          if (z.territoryLayer) {
            z.territoryLayer.unbindTooltip()
            z.territoryLayer.bindTooltip(`${name} Territory`, { sticky: true })
          }
          return { ...z, name }
        }
        return z
      }),
    )
    setEditingZoneId(null)
  }, [])

  const mergeDeliveryZones = useCallback(() => {
    const zonesToMerge = deliveryZones.filter((z) => selectedZonesForMerge.has(z.locationId))
    if (zonesToMerge.length < 2) {
      alert("Select at least 2 zones to merge")
      return
    }

    const newName = prompt(`Merge zones into: ${zonesToMerge.map((z) => z.name).join(", ")}`, zonesToMerge[0].name)
    if (!newName) return

    // Merge all polygons from selected zones
    const mergedSubZones = zonesToMerge.flatMap((z) => z.subZones)
    const mergedZone: DeliveryZone = {
      ...zonesToMerge[0],
      name: newName,
      subZones: mergedSubZones,
      locationId: `merged-${Date.now()}`,
    }

    // Remove old zones and add merged zone
    setDeliveryZones((prev) =>
      [mergedZone, ...prev.filter((z) => !selectedZonesForMerge.has(z.locationId))],
    )

    // Remove old layers from map
    zonesToMerge.forEach((zone) => {
      if (mapInstanceRef.current) {
        mapInstanceRef.current.eachLayer((l: any) => {
          if (l.options && l.options.zoneId === zone.locationId) {
            mapInstanceRef.current.removeLayer(l)
          }
        })
      }
    })

    setSelectedZonesForMerge(new Set())
  }, [deliveryZones, selectedZonesForMerge])

  // Split polygon along a line
  const splitPolygonWithLine = useCallback((polygonGeoJSON: any, lineCoords: [[number, number], [number, number]]) => {
    try {
      const L = (window as any).L
      
      // Create an extended line that goes beyond the polygon bounds
      const [start, end] = lineCoords
      const dx = end[0] - start[0]
      const dy = end[1] - start[1]
      const length = Math.sqrt(dx * dx + dy * dy)
      const scale = 10 / length // Extend the line significantly
      
      const extendedStart: [number, number] = [start[0] - dx * scale, start[1] - dy * scale]
      const extendedEnd: [number, number] = [end[0] + dx * scale, end[1] + dy * scale]
      
      const splittingLine = turf.lineString([extendedStart, extendedEnd])
      
      // Use turf to split the polygon
      const split = turf.lineSplit(turf.polygonToLine(polygonGeoJSON), turf.point(extendedStart))
      
      // Alternative approach: create two polygons by cutting with a buffer
      const lineBuffer = turf.buffer(splittingLine, 0.00001, { units: 'kilometers' })
      
      // Get polygon coords
      const polygonCoords = turf.getCoords(polygonGeoJSON)[0]
      
      // Find intersection points
      const intersections = turf.lineIntersect(splittingLine, turf.polygonToLine(polygonGeoJSON))
      
      if (intersections.features.length < 2) {
        console.log("[v0] Line doesn't cross polygon enough times")
        return null
      }
      
      // Sort intersection points along the line
      const intersectionPoints = intersections.features
        .map(f => turf.getCoord(f) as [number, number])
        .sort((a, b) => {
          const distA = Math.sqrt(Math.pow(a[0] - start[0], 2) + Math.pow(a[1] - start[1], 2))
          const distB = Math.sqrt(Math.pow(b[0] - start[0], 2) + Math.pow(b[1] - start[1], 2))
          return distA - distB
        })
      
      // Create two new polygons by splitting at intersection points
      const point1 = intersectionPoints[0]
      const point2 = intersectionPoints[1]
      
      // Find indices where these points would be inserted
      let insertIdx1 = -1
      let insertIdx2 = -1
      let minDist1 = Infinity
      let minDist2 = Infinity
      
      for (let i = 0; i < polygonCoords.length - 1; i++) {
        const segStart = polygonCoords[i]
        const segEnd = polygonCoords[i + 1]
        const line = turf.lineString([segStart, segEnd])
        
        const dist1 = turf.pointToLineDistance(turf.point(point1), line, { units: 'kilometers' })
        const dist2 = turf.pointToLineDistance(turf.point(point2), line, { units: 'kilometers' })
        
        if (dist1 < minDist1) {
          minDist1 = dist1
          insertIdx1 = i + 1
        }
        if (dist2 < minDist2) {
          minDist2 = dist2
          insertIdx2 = i + 1
        }
      }
      
      // Ensure idx1 < idx2 and swap points if needed
      let finalIdx1 = insertIdx1
      let finalIdx2 = insertIdx2
      let finalPoint1 = point1
      let finalPoint2 = point2
      
      if (insertIdx1 > insertIdx2) {
        finalIdx1 = insertIdx2
        finalIdx2 = insertIdx1
        finalPoint1 = point2
        finalPoint2 = point1
      }
      
      // Create polygon 1: from start to point1, then point2 to end
      const poly1Coords: [number, number][] = [
        ...polygonCoords.slice(0, finalIdx1),
        finalPoint1,
        finalPoint2,
        ...polygonCoords.slice(finalIdx2, -1), // Exclude the closing point
      ]
      poly1Coords.push(poly1Coords[0]) // Close the polygon
      
      // Create polygon 2: from point1 to point2 along the other side
      const poly2Coords: [number, number][] = [
        finalPoint1,
        ...polygonCoords.slice(finalIdx1, finalIdx2),
        finalPoint2,
      ]
      poly2Coords.push(poly2Coords[0]) // Close the polygon
      
      // Validate polygons
      if (poly1Coords.length < 4 || poly2Coords.length < 4) {
        console.log("[v0] Split would create invalid polygons")
        return null
      }
      
      const polygon1 = turf.polygon([poly1Coords])
      const polygon2 = turf.polygon([poly2Coords])
      
      // Validate that both polygons are valid
      if (turf.area(polygon1) < 1 || turf.area(polygon2) < 1) {
        console.log("[v0] Split polygons too small")
        return null
      }
      
      return [polygon1, polygon2]
    } catch (error) {
      console.error("[v0] Error splitting polygon:", error)
      return null
    }
  }, [])

  // Apply split to a polygon in the feature group
  const applySplitToPolygon = useCallback(() => {
    if (!polygonToSplit || splitLines.length === 0 || !mapInstanceRef.current || !featureGroupRef.current) {
      alert("Select a polygon and draw at least one split line")
      return
    }

    const L = (window as any).L
    let currentPolygons: any[] = []
    
    // Find the polygon to split
    featureGroupRef.current.eachLayer((layer: any) => {
      if (layer.options && layer.options.polygonId === polygonToSplit) {
        const geoJSON = layer.toGeoJSON()
        currentPolygons.push({ polygon: geoJSON, layer })
      }
    })

    if (currentPolygons.length === 0) {
      alert("Could not find the selected polygon")
      return
    }

    // Apply each split line
    for (const line of splitLines) {
      const newPolygons: any[] = []
      
      for (const { polygon, layer } of currentPolygons) {
        const result = splitPolygonWithLine(polygon, line)
        
        if (result) {
          newPolygons.push({ polygon: result[0], layer: null })
          newPolygons.push({ polygon: result[1], layer: null })
          
          // Remove the original layer if it exists
          if (layer) {
            featureGroupRef.current.removeLayer(layer)
          }
        } else {
          // Keep the original if split failed
          newPolygons.push({ polygon, layer })
        }
      }
      
      currentPolygons = newPolygons
    }

    // Add the new polygons to the map
    const colors = ["#3b82f6", "#22c55e", "#f59e0b", "#ef4444", "#8b5cf6", "#06b6d4", "#ec4899", "#84cc16"]
    
    currentPolygons.forEach(({ polygon, layer }, idx) => {
      if (!layer) {
        const color = colors[idx % colors.length]
        const newLayer = L.geoJSON(polygon, {
          style: {
            color: color,
            weight: 2,
            fillColor: color,
            fillOpacity: 0.3,
          },
          onEachFeature: (feature: any, lyr: any) => {
            lyr.options.polygonId = `split-${Date.now()}-${idx}`
          }
        })
        
        newLayer.eachLayer((l: any) => {
          featureGroupRef.current.addLayer(l)
        })
      }
    })

    // Clear split state
    setSplitLines([])
    setPolygonToSplit(null)
    setSplitMode(false)
    
    // Clear split lines from map
    if (splitLinesLayerRef.current && mapInstanceRef.current) {
      mapInstanceRef.current.removeLayer(splitLinesLayerRef.current)
      splitLinesLayerRef.current = null
    }

    // Update GeoJSON state
    if (featureGroupRef.current) {
      const newGeoJSON = featureGroupRef.current.toGeoJSON()
      setOriginalGeoJSON(newGeoJSON)
    }

    alert(`Split complete! Created ${currentPolygons.length} regions.`)
  }, [polygonToSplit, splitLines, splitPolygonWithLine])

  // Clear split lines
  const clearSplitLines = useCallback(() => {
    setSplitLines([])
    setCurrentSplitLine(null)
    
    if (splitLinesLayerRef.current && mapInstanceRef.current) {
      mapInstanceRef.current.removeLayer(splitLinesLayerRef.current)
      splitLinesLayerRef.current = null
    }
  }, [])

  const toggleDeliveryZoneVisibility = useCallback((locationId: string) => {
    setDeliveryZones((prev) =>
      prev.map((z) => {
        if (z.locationId === locationId) {
          const newVisible = !z.visible

          if (mapInstanceRef.current) {
            mapInstanceRef.current.eachLayer((layer: any) => {
              if (layer.options && layer.options.zoneId === locationId) {
                if (newVisible) {
                  layer.setStyle({
                    ...layer.options.style,
                    opacity: layer.options.style.opacity || 1,
                    fillOpacity: layer.options.style.fillOpacity || 0.2,
                  })
                } else {
                  layer.setStyle({ opacity: 0, fillOpacity: 0 })
                }
              }
            })
          }

          return { ...z, visible: newVisible }
        }
        return z
      }),
    )
  }, [])

  const checkPointInZone = useCallback(
    (lat: number, lng: number) => {
      const point = turf.point([lng, lat])

      for (const zone of deliveryZones) {
        try {
          const isInTerritory = turf.booleanPointInPolygon(point, zone.territory)
          if (isInTerritory) {
            // Find which sub-zone (drive-time layer)
            let driveTime = "Outside drive-time zones"
            for (let i = zone.subZones.length - 1; i >= 0; i--) {
              const subZone = zone.subZones[i]
              if (turf.booleanPointInPolygon(point, subZone.polygon)) {
                driveTime = `${subZone.time} min zone`
                break
              }
            }

            setLastCheckedPoint({
              lat,
              lng,
              zone: `${zone.name} - ${driveTime}`,
            })

            // Add a temporary marker
            const L = (window as any).L
            const marker = L.marker([lat, lng], {
              icon: L.divIcon({
                className: "bg-yellow-400 rounded-full w-3 h-3 border-2 border-white shadow-lg",
                iconSize: [12, 12],
              }),
            }).addTo(mapInstanceRef.current)

            setTimeout(() => {
              mapInstanceRef.current.removeLayer(marker)
            }, 3000)

            return
          }
        } catch (error) {
          console.log("[v0] Error checking point:", error)
        }
      }

      setLastCheckedPoint({
        lat,
        lng,
        zone: "Not in any delivery zone",
      })
    },
    [deliveryZones],
  )

  useEffect(() => {
    if (!mapInstanceRef.current || !checkPointMode) return

    const handleMapClick = (e: any) => {
      checkPointInZone(e.latlng.lat, e.latlng.lng)
    }

    mapInstanceRef.current.on("click", handleMapClick)

    return () => {
      if (mapInstanceRef.current) {
        mapInstanceRef.current.off("click", handleMapClick)
      }
    }
  }, [checkPointMode, checkPointInZone])

  // Handle split mode clicks
  useEffect(() => {
    if (!mapInstanceRef.current || !splitMode) return

    const L = (window as any).L
    
    const handleSplitClick = (e: any) => {
      const clickedLat = e.latlng.lat
      const clickedLng = e.latlng.lng

      // If no polygon selected yet, check if clicking on a polygon
      if (!polygonToSplit) {
        let foundPolygon = false
        featureGroupRef.current?.eachLayer((layer: any) => {
          if (foundPolygon) return
          
          if (layer.getBounds && layer.getBounds().contains(e.latlng)) {
            const geoJSON = layer.toGeoJSON()
            const point = turf.point([clickedLng, clickedLat])
            
            if (turf.booleanPointInPolygon(point, geoJSON)) {
              const polygonId = layer.options?.polygonId || L.stamp(layer).toString()
              layer.options.polygonId = polygonId
              setPolygonToSplit(polygonId)
              
              // Highlight the selected polygon
              layer.setStyle({ color: '#ef4444', weight: 3 })
              foundPolygon = true
            }
          }
        })
        
        if (!foundPolygon) {
          console.log("[v0] No polygon found at click location")
        }
        return
      }

      // If polygon selected, handle split line drawing
      if (!currentSplitLine) {
        // First point of split line
        setCurrentSplitLine([clickedLng, clickedLat])
        
        // Add a marker for the first point
        const marker = L.circleMarker([clickedLat, clickedLng], {
          radius: 6,
          color: '#ef4444',
          fillColor: '#ef4444',
          fillOpacity: 1,
        }).addTo(mapInstanceRef.current)
        
        if (!splitLinesLayerRef.current) {
          splitLinesLayerRef.current = L.layerGroup().addTo(mapInstanceRef.current)
        }
        splitLinesLayerRef.current.addLayer(marker)
      } else {
        // Second point - complete the line
        const newLine: [[number, number], [number, number]] = [
          currentSplitLine,
          [clickedLng, clickedLat]
        ]
        
        setSplitLines(prev => [...prev, newLine])
        setCurrentSplitLine(null)
        
        // Draw the line on the map
        if (!splitLinesLayerRef.current) {
          splitLinesLayerRef.current = L.layerGroup().addTo(mapInstanceRef.current)
        }
        
        const lineLayer = L.polyline(
          [[currentSplitLine[1], currentSplitLine[0]], [clickedLat, clickedLng]],
          { color: '#ef4444', weight: 3, dashArray: '10, 5' }
        )
        splitLinesLayerRef.current.addLayer(lineLayer)
        
        // Add end point marker
        const marker = L.circleMarker([clickedLat, clickedLng], {
          radius: 6,
          color: '#ef4444',
          fillColor: '#ef4444',
          fillOpacity: 1,
        })
        splitLinesLayerRef.current.addLayer(marker)
      }
    }

    mapInstanceRef.current.on("click", handleSplitClick)

    return () => {
      if (mapInstanceRef.current) {
        mapInstanceRef.current.off("click", handleSplitClick)
      }
    }
  }, [splitMode, polygonToSplit, currentSplitLine])

  const generateIsochrone = async () => {
    if (!isMapReady || !mapInstanceRef.current) return

    const lat = Number.parseFloat(latitude)
    const lng = Number.parseFloat(longitude)
    const minutes = Number.parseInt(driveTime)

    if (isNaN(lat) || isNaN(lng) || isNaN(minutes)) {
      alert("Please enter valid coordinates and drive time")
      return
    }

    setIsGenerating(true)

    try {
      const L = (window as any).L
      const radiusKm = minutes * 1
      const center = turf.point([lng, lat])

      if (!apiKey || useCircularFallback) {
        const circle = turf.circle(center, radiusKm, { steps: 32, units: "kilometers" })
        const simplified = turf.simplify(circle, { tolerance: 0.001, highQuality: true })

        L.geoJSON(simplified, {
          onEachFeature: (feature: any, layer: any) => {
            featureGroupRef.current?.addLayer(layer)

            const newPolygon: PolygonMetadata = {
              id: L.stamp(layer).toString(),
              name: `Zone ${polygons.length + 1}`,
              color: "#3b82f6",
              visible: true,
              layer: layer,
            }

            setPolygons((prev) => [...prev, newPolygon])
          },
        })

        L.marker([lat, lng], {
          icon: L.divIcon({
            className: "bg-blue-500 rounded-full w-3 h-3 border-2 border-white",
            iconSize: [12, 12],
          }),
        }).addTo(mapInstanceRef.current)

        const bounds = featureGroupRef.current.getBounds()
        if (bounds.isValid()) {
          mapInstanceRef.current.fitBounds(bounds, { padding: [50, 50] })
        }

        updateGeoJSON()
      } else {
        const response = await fetch("/api/isochrone", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            apiKey,
            locations: [[lng, lat]],
            range: [minutes * 60],
            range_type: "time",
          }),
        })

        if (!response.ok) {
          const errorData = await response.json().catch(() => ({}))
          console.error("[v0] API error:", response.status, errorData)
          throw new Error(errorData.error || `Failed to generate isochrone: ${response.status}`)
        }

        const data = await response.json()
        const simplified = turf.simplify(data, { tolerance: 0.001, highQuality: true })

        L.geoJSON(simplified, {
          onEachFeature: (feature: any, layer: any) => {
            featureGroupRef.current?.addLayer(layer)

            const newPolygon: PolygonMetadata = {
              id: L.stamp(layer).toString(),
              name: `Zone ${polygons.length + 1}`,
              color: "#3b82f6",
              visible: true,
              layer: layer,
            }

            setPolygons((prev) => [...prev, newPolygon])
          },
        })

        L.marker([lat, lng], {
          icon: L.divIcon({
            className: "bg-blue-500 rounded-full w-3 h-3 border-2 border-white",
            iconSize: [12, 12],
          }),
        }).addTo(mapInstanceRef.current)

        const bounds = featureGroupRef.current.getBounds()
        if (bounds.isValid()) {
          mapInstanceRef.current.fitBounds(bounds, { padding: [50, 50] })
        }

        updateGeoJSON()
      }
    } catch (error) {
      console.error("Error generating isochrone:", error)
      alert("Failed to generate drive-time polygon. Using approximate circular boundary.")

      const L = (window as any).L
      const radiusKm = Number.parseInt(driveTime) * 1
      const center = turf.point([Number.parseFloat(longitude), Number.parseFloat(latitude)])
      const circle = turf.circle(center, radiusKm, { steps: 32, units: "kilometers" })
      const simplified = turf.simplify(circle, { tolerance: 0.001, highQuality: true })

      L.geoJSON(simplified, {
        onEachFeature: (feature: any, layer: any) => {
          featureGroupRef.current?.addLayer(layer)

          const newPolygon: PolygonMetadata = {
            id: L.stamp(layer).toString(),
            name: `Zone ${polygons.length + 1}`,
            color: "#3b82f6",
            visible: true,
            layer: layer,
          }

          setPolygons((prev) => [...prev, newPolygon])
        },
      })

      L.marker([lat, lng], {
        icon: L.divIcon({
          className: "bg-blue-500 rounded-full w-3 h-3 border-2 border-white",
          iconSize: [12, 12],
        }),
      }).addTo(mapInstanceRef.current)

      const bounds = featureGroupRef.current.getBounds()
      if (bounds.isValid()) {
        mapInstanceRef.current.fitBounds(bounds, { padding: [50, 50] })
      }

      updateGeoJSON()
    } finally {
      setIsGenerating(false)
    }
  }

  const deleteSelectedVertices = useCallback(() => {
    if (!featureGroupRef.current || selectedVertices.size === 0) return

    const L = (window as any).L
    const verticesToDelete = new Map<any, Set<number>>()

    selectedVertices.forEach((vertexId) => {
      const [layerStamp, indexStr] = vertexId.split("-")
      const index = Number.parseInt(indexStr)

      featureGroupRef.current.eachLayer((layer: any) => {
        if (L.stamp(layer).toString() === layerStamp) {
          if (!verticesToDelete.has(layer)) {
            verticesToDelete.set(layer, new Set())
          }
          verticesToDelete.get(layer)?.add(index)
        }
      })
    })

    verticesToDelete.forEach((indices, layer) => {
      const latlngs = layer.getLatLngs()[0]
      const sortedIndices = Array.from(indices).sort((a, b) => b - a)

      sortedIndices.forEach((index) => {
        latlngs.splice(index, 1)
      })

      if (latlngs.length >= 3) {
        featureGroupRef.current.removeLayer(layer)

        const newPolygon = L.polygon(latlngs, {
          color: showSimplified ? "#10b981" : "#3b82f6",
          weight: 2,
          fillOpacity: 0.2,
        })

        featureGroupRef.current.addLayer(newPolygon)
      } else {
        featureGroupRef.current.removeLayer(layer)
      }
    })

    selectedMarkersRef.current.forEach((marker) => {
      if (mapInstanceRef.current) {
        mapInstanceRef.current.removeLayer(marker)
      }
    })
    selectedMarkersRef.current.clear()
    setSelectedVertices(new Set())

    updateGeoJSON()
  }, [selectedVertices, updateGeoJSON, showSimplified])

  useEffect(() => {
    if (!featureGroupRef.current || !isMapReady) return

    const updateColors = async () => {
      const L = (window as any).L
      featureGroupRef.current.eachLayer((layer: any) => {
        if (layer.setStyle) {
          layer.setStyle({
            color: showSimplified ? "#10b981" : "#3b82f6",
            weight: 2,
            fillOpacity: 0.2,
          })
        }
      })
    }

    updateColors()
  }, [showSimplified, isMapReady])

  const handleDownload = () => {
    const dataToDownload = showSimplified ? simplifiedGeoJSON : originalGeoJSON
    if (!dataToDownload) return

    const dataStr = JSON.stringify(dataToDownload, null, 2)
    const dataBlob = new Blob([dataStr], { type: "application/json" })
    const url = URL.createObjectURL(dataBlob)
    const link = document.createElement("a")
    link.href = url
    link.download = "polygons.geojson"
    document.body.appendChild(link)
    link.click()
    document.body.removeChild(link)
    URL.revokeObjectURL(url)
  }

  const handleUpload = async (event: React.ChangeEvent<HTMLInputElement>) => {
    const file = event.target.files?.[0]
    if (!file || !isMapReady) return

    const reader = new FileReader()
    reader.onload = async (e) => {
      try {
        const L = (window as any).L
        const geojson = JSON.parse(e.target?.result as string)
        setOriginalGeoJSON(geojson)

        if (featureGroupRef.current && mapInstanceRef.current) {
          L.geoJSON(geojson, {
            onEachFeature: (feature: any, layer: any) => {
              if (layer.setStyle) {
                layer.setStyle({
                  color: "#3b82f6",
                  weight: 2,
                  fillOpacity: 0.2,
                })
              }
              featureGroupRef.current?.addLayer(layer)

              const newPolygon: PolygonMetadata = {
                id: L.stamp(layer).toString(),
                name: `Zone ${polygons.length + 1}`,
                color: "#3b82f6",
                visible: true,
                layer: layer,
              }

              setPolygons((prev) => [...prev, newPolygon])
            },
          })

          const bounds = featureGroupRef.current.getBounds()
          if (bounds.isValid()) {
            mapInstanceRef.current.fitBounds(bounds, { padding: [50, 50] })
          }
        }

        updateGeoJSON()
      } catch (error) {
        console.error("Error parsing GeoJSON:", error)
        alert("Invalid GeoJSON file")
      }
    }
    reader.readAsText(file)

    if (fileInputRef.current) {
      fileInputRef.current.value = ""
    }
  }

  useEffect(() => {
    if (!multiSelectMode && selectedVertices.size > 0) {
      selectedMarkersRef.current.forEach((marker) => {
        if (mapInstanceRef.current) {
          mapInstanceRef.current.removeLayer(marker)
        }
      })
      selectedMarkersRef.current.clear()
      setSelectedVertices(new Set())
    }

    if (!multiSelectMode && mapInstanceRef.current && mapInstanceRef.current.dragging) {
      mapInstanceRef.current.dragging.enable()
    }
  }, [multiSelectMode, selectedVertices.size])

  const togglePolygonVisibility = useCallback((id: string) => {
    setPolygons((prev) =>
      prev.map((p) => {
        if (p.id === id) {
          const newVisible = !p.visible
          if (p.layer) {
            if (newVisible) {
              featureGroupRef.current?.addLayer(p.layer)
            } else {
              featureGroupRef.current?.removeLayer(p.layer)
            }
          }
          return { ...p, visible: newVisible }
        }
        return p
      }),
    )
  }, [])

  const updatePolygonColor = useCallback((id: string, color: string) => {
    setPolygons((prev) =>
      prev.map((p) => {
        if (p.id === id && p.layer && p.layer.setStyle) {
          p.layer.setStyle({ color, weight: 2, fillOpacity: 0.2 })
          return { ...p, color }
        }
        return p
      }),
    )
  }, [])

  const renamePolygon = useCallback((id: string, name: string) => {
    setPolygons((prev) => prev.map((p) => (p.id === id ? { ...p, name } : p)))
    setEditingPolygonId(null)
  }, [])

  const exportDeliveryZone = useCallback((zone: DeliveryZone) => {
    const features = [
      {
        type: "Feature",
        properties: {
          name: zone.name,
          type: "territory",
          color: zone.color,
        },
        geometry: zone.territory.geometry,
      },
      ...zone.subZones.map((subZone) => ({
        type: "Feature",
        properties: {
          name: `${zone.name} - ${subZone.time} min`,
          type: "subzone",
          driveTime: subZone.time,
          color: zone.color,
        },
        geometry: subZone.polygon.geometry,
      })),
    ]

    const geojson = {
      type: "FeatureCollection",
      features,
    }

    const dataStr = JSON.stringify(geojson, null, 2)
    const dataBlob = new Blob([dataStr], { type: "application/json" })
    const url = URL.createObjectURL(dataBlob)
    const link = document.createElement("a")
    link.href = url
    link.download = `${zone.name.replace(/\s+/g, "_")}.geojson`
    document.body.appendChild(link)
    link.click()
    document.body.removeChild(link)
    URL.revokeObjectURL(url)
  }, [])

  const exportAllZones = useCallback(() => {
    const features = deliveryZones.flatMap((zone) => [
      {
        type: "Feature",
        properties: {
          name: zone.name,
          type: "territory",
          color: zone.color,
        },
        geometry: zone.territory.geometry,
      },
      ...zone.subZones.map((subZone) => ({
        type: "Feature",
        properties: {
          name: `${zone.name} - ${subZone.time} min`,
          type: "subzone",
          driveTime: subZone.time,
          color: zone.color,
        },
        geometry: subZone.polygon.geometry,
      })),
    ])

    const geojson = {
      type: "FeatureCollection",
      features,
    }

    const dataStr = JSON.stringify(geojson, null, 2)
    const dataBlob = new Blob([dataStr], { type: "application/json" })
    const url = URL.createObjectURL(dataBlob)
    const link = document.createElement("a")
    link.href = url
    link.download = "all_delivery_zones.geojson"
    document.body.appendChild(link)
    link.click()
    document.body.removeChild(link)
    URL.revokeObjectURL(url)
  }, [deliveryZones])

  const exportDriveTimeLayer = useCallback(
    (driveTime: number) => {
      const features = deliveryZones
        .flatMap((zone) => {
          const subZone = zone.subZones.find((sz) => sz.time === driveTime)
          if (!subZone) return []
          return [
            {
              type: "Feature",
              properties: {
                name: `${zone.name} - ${driveTime} min`,
                type: "subzone",
                driveTime: driveTime,
                color: zone.color,
                location: zone.name,
              },
              geometry: subZone.polygon.geometry,
            },
          ]
        })
        .filter((f) => f)

      if (features.length === 0) {
        alert(`No ${driveTime}-minute zones found`)
        return
      }

      const geojson = {
        type: "FeatureCollection",
        features,
      }

      const dataStr = JSON.stringify(geojson, null, 2)
      const dataBlob = new Blob([dataStr], { type: "application/json" })
      const url = URL.createObjectURL(dataBlob)
      const link = document.createElement("a")
      link.href = url
      link.download = `${driveTime}_minute_zones.geojson`
      document.body.appendChild(link)
      link.click()
      document.body.removeChild(link)
      URL.revokeObjectURL(url)
    },
    [deliveryZones],
  )

  return (
    <div className="relative h-full w-full">
      {isDragging && dragStart && dragEnd && (
        <div
          className="fixed z-[1001] border-2 border-blue-500 bg-blue-500/20 pointer-events-none"
          style={{
            left: Math.min(dragStart.x, dragEnd.x),
            top: Math.min(dragStart.y, dragEnd.y),
            width: Math.abs(dragEnd.x - dragStart.x),
            height: Math.abs(dragEnd.y - dragStart.y),
          }}
        />
      )}

      {contextMenu && (
        <div
          ref={contextMenuRef}
          className="fixed z-[1002] bg-white rounded-lg shadow-lg border border-gray-200 p-2 min-w-[200px]"
          style={{ left: contextMenu.x, top: contextMenu.y }}
        >
          <div className="text-xs text-gray-600 px-2 py-1 border-b border-gray-200 mb-1">
            <div>Lat: {contextMenu.lat.toFixed(6)}</div>
            <div>Lng: {contextMenu.lng.toFixed(6)}</div>
          </div>
          <Button
            size="sm"
            variant="ghost"
            className="w-full justify-start text-xs"
            onClick={() => copyCoordinates(contextMenu.lat, contextMenu.lng)}
          >
            <Copy className="mr-2 h-3 w-3" />
            Copy Coordinates
          </Button>
          <Button
            size="sm"
            variant="ghost"
            className="w-full justify-start text-xs"
            onClick={() => addLocationCenter(contextMenu.lat, contextMenu.lng)}
          >
            <Plus className="mr-2 h-3 w-3" />
            Add as Location Center
          </Button>
        </div>
      )}

      <Card className="absolute left-12 top-4 z-[1000] w-64 max-h-[calc(100vh-2rem)] overflow-y-auto p-4">
        <div className="space-y-4">
          {polygons.length > 0 && (
            <div className="space-y-2">
              <h3 className="text-sm font-semibold">Zones</h3>
              <div className="space-y-1 max-h-48 overflow-y-auto">
                {polygons.map((polygon) => (
                  <div
                    key={polygon.id}
                    className={`flex items-center gap-2 p-2 rounded border ${
                      selectedPolygonId === polygon.id ? "border-blue-500 bg-blue-50" : "border-gray-200"
                    }`}
                    onClick={() => setSelectedPolygonId(polygon.id)}
                  >
                    <button
                      onClick={(e) => {
                        e.stopPropagation()
                        togglePolygonVisibility(polygon.id)
                      }}
                      className="shrink-0"
                    >
                      {polygon.visible ? (
                        <Eye className="h-4 w-4 text-gray-600" />
                      ) : (
                        <EyeOff className="h-4 w-4 text-gray-400" />
                      )}
                    </button>

                    <input
                      type="color"
                      value={polygon.color}
                      onChange={(e) => {
                        e.stopPropagation()
                        updatePolygonColor(polygon.id, e.target.value)
                      }}
                      className="w-6 h-6 rounded cursor-pointer shrink-0"
                    />

                    {editingPolygonId === polygon.id ? (
                      <Input
                        value={editingName}
                        onChange={(e) => setEditingName(e.target.value)}
                        onBlur={() => renamePolygon(polygon.id, editingName)}
                        onKeyDown={(e) => {
                          if (e.key === "Enter") renamePolygon(polygon.id, editingName)
                          if (e.key === "Escape") setEditingPolygonId(null)
                        }}
                        className="h-6 text-xs flex-1"
                        autoFocus
                        onClick={(e) => e.stopPropagation()}
                      />
                    ) : (
                      <>
                        <span className="text-xs flex-1 truncate">{polygon.name}</span>
                        <button
                          onClick={(e) => {
                            e.stopPropagation()
                            setEditingPolygonId(polygon.id)
                            setEditingName(polygon.name)
                          }}
                          className="shrink-0"
                        >
                          <Edit2 className="h-3 w-3 text-gray-400 hover:text-gray-600" />
                        </button>
                      </>
                    )}
                  </div>
                ))}
              </div>
              <p className="text-xs text-muted-foreground">Click a zone to select it for adding points</p>
            </div>
          )}

          <div className="space-y-2 border-t border-border pt-4">
            <h3 className="text-sm font-semibold">Vertex Editing</h3>
            <div className="flex items-center gap-2">
              <Switch id="multi-select-mode" checked={multiSelectMode} onCheckedChange={setMultiSelectMode} />
              <Label htmlFor="multi-select-mode" className="text-sm">
                Multi-Select Mode
              </Label>
            </div>
            {multiSelectMode && (
              <div className="space-y-2 pt-2">
                <p className="text-xs text-muted-foreground">
                  Drag across the map to select multiple vertices. Selected vertices will be highlighted in red.
                </p>
                <Button
                  onClick={deleteSelectedVertices}
                  size="sm"
                  variant="destructive"
                  className="w-full"
                  disabled={selectedVertices.size === 0}
                >
                  <Trash2 className="mr-2 h-4 w-4" />
                  Delete {selectedVertices.size > 0 ? `(${selectedVertices.size})` : ""}
                </Button>
              </div>
            )}
          </div>

          {/* Region Split Mode */}
          <div className="space-y-2 border-t border-border pt-4">
            <div className="flex items-center gap-2">
              <Scissors className="h-4 w-4 text-muted-foreground" />
              <h3 className="text-sm font-semibold">Region Split</h3>
            </div>
            <div className="flex items-center gap-2">
              <Switch 
                id="split-mode" 
                checked={splitMode} 
                onCheckedChange={(checked) => {
                  setSplitMode(checked)
                  if (!checked) {
                    clearSplitLines()
                    setPolygonToSplit(null)
                  }
                }} 
              />
              <Label htmlFor="split-mode" className="text-sm">
                Split Mode
              </Label>
            </div>
            {splitMode && (
              <div className="space-y-2 pt-2">
                <p className="text-xs text-muted-foreground">
                  1. Click on a polygon to select it for splitting
                </p>
                <p className="text-xs text-muted-foreground">
                  2. Click two points to draw a split line across the polygon
                </p>
                <p className="text-xs text-muted-foreground">
                  3. Add more lines to create more regions
                </p>
                
                {polygonToSplit && (
                  <div className="text-xs bg-blue-100 dark:bg-blue-900 p-2 rounded">
                    Polygon selected. Click to draw split lines.
                  </div>
                )}
                
                {splitLines.length > 0 && (
                  <div className="text-xs text-muted-foreground">
                    {splitLines.length} split line(s) drawn
                  </div>
                )}
                
                <div className="flex gap-2">
                  <Button
                    onClick={applySplitToPolygon}
                    size="sm"
                    variant="default"
                    className="flex-1"
                    disabled={!polygonToSplit || splitLines.length === 0}
                  >
                    <Scissors className="mr-2 h-4 w-4" />
                    Split ({splitLines.length})
                  </Button>
                  <Button
                    onClick={() => {
                      clearSplitLines()
                      setPolygonToSplit(null)
                    }}
                    size="sm"
                    variant="outline"
                  >
                    Clear
                  </Button>
                </div>
              </div>
            )}
          </div>

          <div className="space-y-2 border-t border-border pt-4">
            <div className="flex items-center gap-2">
              <MapPin className="h-4 w-4 text-muted-foreground" />
              <h3 className="text-sm font-semibold">Drive-Time Zones</h3>
            </div>

            <div className="space-y-2">
              {/* Mode Toggle */}
              <div className="flex gap-2 p-1 bg-muted rounded-lg">
                <button
                  onClick={() => setZoneMode("single")}
                  className={`flex-1 px-3 py-1.5 text-xs rounded transition-colors ${
                    zoneMode === "single"
                      ? "bg-background shadow-sm font-medium"
                      : "text-muted-foreground hover:text-foreground"
                  }`}
                >
                  Single Zone
                </button>
                <button
                  onClick={() => setZoneMode("multi")}
                  className={`flex-1 px-3 py-1.5 text-xs rounded transition-colors ${
                    zoneMode === "multi"
                      ? "bg-background shadow-sm font-medium"
                      : "text-muted-foreground hover:text-foreground"
                  }`}
                >
                  Multi-Zone
                </button>
              </div>

{/* API Key (shared) */}
  <div>
  <Label htmlFor="api-key" className="text-xs">
    OpenRouteService API Key
  </Label>
  <Input
  id="api-key"
  value={apiKey}
  onChange={(e) => setApiKey(e.target.value)}
  placeholder="Get free key at openrouteservice.org"
  className="h-8 text-xs font-mono"
  />
  <p className="text-xs text-muted-foreground mt-1">
    <a href="https://openrouteservice.org/dev/#/signup" target="_blank" rel="noopener noreferrer" className="underline">
      Get a free API key
    </a>
  </p>
  </div>
  
  <div className="flex items-center gap-2">
  <Switch
    id="circular-fallback"
    checked={useCircularFallback}
    onCheckedChange={setUseCircularFallback}
  />
  <Label htmlFor="circular-fallback" className="text-xs">
    Use circular approximation (no API needed)
  </Label>
  </div>

              {/* Single Zone Mode */}
              {zoneMode === "single" && (
                <>
                  <div className="grid grid-cols-2 gap-2">
                    <div>
                      <Label htmlFor="latitude" className="text-xs">
                        Latitude
                      </Label>
                      <Input
                        id="latitude"
                        value={latitude}
                        onChange={(e) => setLatitude(e.target.value)}
                        placeholder="33.4484"
                        className="h-8 text-xs"
                      />
                    </div>
                    <div>
                      <Label htmlFor="longitude" className="text-xs">
                        Longitude
                      </Label>
                      <Input
                        id="longitude"
                        value={longitude}
                        onChange={(e) => setLongitude(e.target.value)}
                        placeholder="-112.074"
                        className="h-8 text-xs"
                      />
                    </div>
                  </div>
                  <div>
                    <Label htmlFor="drive-time" className="text-xs">
                      Drive Time (minutes)
                    </Label>
                    <Input
                      id="drive-time"
                      value={driveTime}
                      onChange={(e) => setDriveTime(e.target.value)}
                      placeholder="15"
                      className="h-8 text-xs"
                    />
                  </div>
                  <Button onClick={generateIsochrone} size="sm" className="w-full" disabled={isGenerating}>
                    {isGenerating ? "Generating..." : "Generate Zone"}
                  </Button>
                </>
              )}

              {/* Multi-Zone Mode */}
              {zoneMode === "multi" && (
                <>
                  <div>
                    <Label htmlFor="multi-locations" className="text-xs">
                      Locations (lat,lng per line)
                    </Label>
                    <textarea
                      id="multi-locations"
                      value={multiLocations}
                      onChange={(e) => setMultiLocations(e.target.value)}
                      placeholder="33.4484,-112.074&#10;33.5484,-112.174"
                      className="w-full h-20 text-xs p-2 border rounded resize-none font-mono"
                    />
                  </div>
                  <div>
                    <Label htmlFor="multi-times" className="text-xs">
                      Drive Times (comma-separated)
                    </Label>
                    <Input
                      id="multi-times"
                      value={multiDriveTimes}
                      onChange={(e) => setMultiDriveTimes(e.target.value)}
                      placeholder="5,10,15,20"
                      className="h-8 text-xs font-mono"
                    />
                  </div>
                  <Button onClick={generateDeliveryZones} size="sm" className="w-full" disabled={isGenerating}>
                    {isGenerating ? "Generating..." : "Generate Delivery Zones"}
                  </Button>
                  <p className="text-[10px] text-muted-foreground">
                    Creates non-overlapping territories with nested drive-time sub-zones
                  </p>
                </>
              )}

              <p className="text-[10px] text-muted-foreground">
                {apiKey
                  ? "Using OpenRouteService API for accurate drive times"
                  : "Without API key, uses circular approximation"}
              </p>
            </div>
          </div>

          {deliveryZones.length > 0 && (
            <div className="space-y-2 border-t border-border pt-4">
              <div className="flex items-center gap-2">
                <Target className="h-4 w-4 text-muted-foreground" />
                <h3 className="text-sm font-semibold">Zone Checker</h3>
              </div>
              <div className="flex items-center gap-2">
                <Switch id="check-point-mode" checked={checkPointMode} onCheckedChange={setCheckPointMode} />
                <Label htmlFor="check-point-mode" className="text-xs">
                  Check Point Mode
                </Label>
              </div>
              {checkPointMode && (
                <p className="text-xs text-muted-foreground">
                  Click anywhere on the map to check which zone it belongs to
                </p>
              )}
              {lastCheckedPoint && (
                <div className="bg-blue-50 border border-blue-200 rounded p-2 text-xs">
                  <div className="font-semibold text-blue-900">Result:</div>
                  <div className="text-blue-700">{lastCheckedPoint.zone}</div>
                  <div className="text-blue-600 text-[10px] mt-1">
                    {lastCheckedPoint.lat.toFixed(6)}, {lastCheckedPoint.lng.toFixed(6)}
                  </div>
                </div>
              )}
            </div>
          )}

          {deliveryZones.length > 0 && (
            <div className="space-y-2 border-t border-border pt-4">
              <h3 className="text-sm font-semibold">Active Delivery Zones</h3>
              <div className="space-y-1 max-h-48 overflow-y-auto">
                {deliveryZones.map((zone, idx) => (
                  <div key={zone.locationId} className="flex items-center gap-2 p-2 rounded border border-gray-200">
                    <input
                      type="checkbox"
                      checked={selectedZonesForMerge.has(zone.locationId)}
                      onChange={(e) => {
                        const newSelected = new Set(selectedZonesForMerge)
                        if (e.target.checked) {
                          newSelected.add(zone.locationId)
                        } else {
                          newSelected.delete(zone.locationId)
                        }
                        setSelectedZonesForMerge(newSelected)
                      }}
                      className="shrink-0"
                    />
                    <button
                      onClick={(e) => {
                        e.stopPropagation()
                        toggleDeliveryZoneVisibility(zone.locationId)
                      }}
                      className="shrink-0"
                    >
                      {zone.visible ? (
                        <Eye className="h-4 w-4 text-gray-600" />
                      ) : (
                        <EyeOff className="h-4 w-4 text-gray-400" />
                      )}
                    </button>

                    <div className="w-3 h-3 rounded-full shrink-0" style={{ backgroundColor: zone.color }} />

                    {editingZoneId === zone.locationId ? (
                      <Input
                        value={editingZoneName}
                        onChange={(e) => setEditingZoneName(e.target.value)}
                        onBlur={() => renameDeliveryZone(zone.locationId, editingZoneName)}
                        onKeyDown={(e) => {
                          if (e.key === "Enter") renameDeliveryZone(zone.locationId, editingZoneName)
                          if (e.key === "Escape") setEditingZoneId(null)
                        }}
                        className="h-6 text-xs flex-1"
                        autoFocus
                        onClick={(e) => e.stopPropagation()}
                      />
                    ) : (
                      <div className="flex-1 min-w-0 flex items-center gap-2">
                        <div>
                          <div className="text-xs font-medium truncate">{zone.name}</div>
                          <div className="text-[10px] text-muted-foreground">
                            {zone.subZones.length} drive-time layers
                          </div>
                        </div>
                        <button
                          onClick={(e) => {
                            e.stopPropagation()
                            setEditingZoneId(zone.locationId)
                            setEditingZoneName(zone.name)
                          }}
                          className="shrink-0"
                        >
                          <Edit2 className="h-3 w-3 text-gray-400 hover:text-gray-600" />
                        </button>
                      </div>
                    )}

                    <Button
                      size="sm"
                      variant="ghost"
                      className="h-6 w-6 p-0 shrink-0"
                      onClick={() => exportDeliveryZone(zone)}
                      title="Export this zone"
                    >
                      <Download className="h-3 w-3" />
                    </Button>

                    <Button
                      size="sm"
                      variant="ghost"
                      className="h-6 w-6 p-0 shrink-0 text-red-500 hover:text-red-700"
                      onClick={() => {
                        if (confirm(`Delete "${zone.name}"?`)) {
                          setDeliveryZones((prev) => prev.filter((z) => z.locationId !== zone.locationId))
                          if (mapInstanceRef.current) {
                            mapInstanceRef.current.eachLayer((l: any) => {
                              if (l.options && l.options.zoneId === zone.locationId) {
                                mapInstanceRef.current.removeLayer(l)
                              }
                            })
                          }
                        }
                      }}
                      title="Delete this zone"
                    >
                      <Trash2 className="h-3 w-3" />
                    </Button>
                  </div>
                ))}
              </div>
              <div className="space-y-2 pt-2">
                {selectedZonesForMerge.size > 0 && (
                  <div className="flex gap-2">
                    <Button
                      size="sm"
                      variant="outline"
                      className="flex-1 text-xs"
                      onClick={mergeDeliveryZones}
                    >
                      Merge ({selectedZonesForMerge.size})
                    </Button>
                    <Button
                      size="sm"
                      variant="ghost"
                      className="px-2 text-xs"
                      onClick={() => setSelectedZonesForMerge(new Set())}
                    >
                      Clear
                    </Button>
                  </div>
                )}
                <Button size="sm" variant="outline" className="w-full text-xs bg-transparent" onClick={exportAllZones}>
                  <Download className="mr-2 h-3 w-3" />
                  Export All Zones
                </Button>
                {deliveryZones.length > 0 && deliveryZones[0].subZones.length > 0 && (
                  <div className="space-y-1">
                    <Label className="text-xs text-muted-foreground">Export by Drive Time:</Label>
                    <div className="flex flex-wrap gap-1">
                      {Array.from(new Set(deliveryZones[0].subZones.map((sz) => sz.time))).map((time) => (
                        <Button
                          key={time}
                          size="sm"
                          variant="outline"
                          className="text-xs h-6 px-2 bg-transparent"
                          onClick={() => exportDriveTimeLayer(time)}
                        >
                          {time} min
                        </Button>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            </div>
          )}

          <div className="space-y-2 border-t border-border pt-4">
            <h3 className="text-sm font-semibold">File Operations</h3>
            <div className="flex gap-2">
              <Button onClick={() => fileInputRef.current?.click()} size="sm" variant="secondary" className="flex-1">
                <Upload className="mr-2 h-4 w-4" />
                Upload
              </Button>
              <Button
                onClick={handleDownload}
                size="sm"
                variant="secondary"
                className="flex-1"
                disabled={!originalGeoJSON}
              >
                <Download className="mr-2 h-4 w-4" />
                Download
              </Button>
            </div>
            <p className="text-[10px] text-muted-foreground">
              Upload/Download manually drawn polygons (editable layers only)
            </p>
            <input ref={fileInputRef} type="file" accept=".geojson,.json" onChange={handleUpload} className="hidden" />
          </div>

          <div className="space-y-2 border-t border-border pt-4">
            <h3 className="text-sm font-semibold">Simplification</h3>
            <div className="flex items-center gap-2">
              <Switch id="simplified-mode" checked={showSimplified} onCheckedChange={setShowSimplified} />
              <Label htmlFor="simplified-mode" className="text-xs">
                Show Simplified
              </Label>
            </div>

            {showSimplified && (
              <div className="space-y-2 pt-2">
                <div className="flex items-center justify-between">
                  <Label htmlFor="tolerance-slider" className="text-xs text-muted-foreground">
                    Tolerance
                  </Label>
                  <span className="text-xs font-mono text-muted-foreground">{tolerance.toFixed(4)}</span>
                </div>
                <Slider
                  id="tolerance-slider"
                  min={0.0001}
                  max={0.01}
                  step={0.0001}
                  value={[tolerance]}
                  onValueChange={(value) => setTolerance(value[0])}
                />
              </div>
            )}
          </div>

          {stats && stats.count > 0 && (
            <div className="space-y-2 border-t border-border pt-4">
              <div className="flex items-center gap-2">
                <Info className="h-4 w-4 text-muted-foreground" />
                <h3 className="text-sm font-semibold">Statistics</h3>
              </div>
              <div className="space-y-1 text-sm">
                <div className="flex justify-between">
                  <span className="text-muted-foreground">Polygons:</span>
                  <span className="font-medium">{stats.count}</span>
                </div>
                <div className="flex justify-between">
                  <span className="text-muted-foreground">Total Area:</span>
                  <span className="font-medium">{(stats.area / 1000000).toFixed(2)} km²</span>
                </div>
                <div className="flex justify-between">
                  <span className="text-muted-foreground">Perimeter:</span>
                  <span className="font-medium">{(stats.perimeter / 1000).toFixed(2)} km</span>
                </div>
              </div>
            </div>
          )}
        </div>
      </Card>

      <div ref={mapRef} className="h-full w-full" />
    </div>
  )
}
